# Pinned upstream revisions for Nidara's source-built dependency packages.
#
# This is the single source of truth for THIS repo's build. It is kept in
# LOCKSTEP with nidara-desktop/install.sh (its ASTAL_REF / AGS_REF / APPMENU_REF)
# until install.sh consumes this repo (then this file becomes the only SoT).
#
# Astal has no git tags -> pinned by commit SHA. AGS is pinned by release tag.
ASTAL_REF=948805f6e8cf7f8c08eba06ab1db1eef0e75e3a0
AGS_REF=v3.1.2
APPMENU_REF=aea4ea398b7c75494f23f5e5bdb4f495d615059f

# Nidara itself — the desktop package. build-repo.sh builds it from this
# nidara-desktop release TAG, with the PKGBUILD that ships INSIDE the tag
# (packaging/nidara/) — nothing about nidara's layout is committed here.
# Release runbook: tag nidara-desktop first, then point this at the new tag
# (one line) and push — CI rebuilds and republishes the repo.
# Empty = skip (releases predating the packaging switch).
NIDARA_REF=v0.3.0
